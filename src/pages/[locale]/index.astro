---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import StatsBar from '../../components/StatsBar.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { getLocale, t } from '../../i18n';
import type { Locale } from '../../i18n';

export function getStaticPaths() {
  return [{ params: { locale: 'zh' } }, { params: { locale: 'en' } }];
}

const locale = getLocale(Astro.url) as Locale;
const i18n = t(locale);

const allProjects = await getCollection('projects');
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<Base title={`${i18n.site.slogan} — ${i18n.site.subtitle}`} description={i18n.hero.description}>
  <Header />
  <main class="flex-1">
    <Hero />
    <StatsBar />

    <section class="py-20">
      <div class="mx-auto max-w-6xl px-6">
        <div class="text-center mb-12 animate-fade-in-up">
          <h2 class="text-3xl md:text-4xl font-bold font-[var(--font-heading)]">
            {i18n.projects.title}
          </h2>
          <p class="mt-3 text-[var(--color-text-secondary)]">
            {i18n.projects.subtitle}
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6 animate-fade-in-up animate-delay-100">
          {featured.map((project) => (
            <ProjectCard
              name={project.data.name}
              slug={project.data.slug}
              tagline={project.data.tagline}
              category={project.data.category}
              status={project.data.status}
              logo={project.data.logo}
              github={project.data.github}
              website={project.data.website}
              locale={locale}
            />
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>
