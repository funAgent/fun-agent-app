---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getLocale, t } from '../../i18n';

export function getStaticPaths() {
  return [{ params: { locale: 'zh' } }, { params: { locale: 'en' } }];
}

const locale = getLocale(Astro.url);
const i18n = t(locale);
---

<Base title={i18n.about.title} description={i18n.about.missionText}>
  <Header />
  <main class="flex-1 pt-24 pb-20">
    <div class="mx-auto max-w-3xl px-6">
      <h1 class="text-4xl md:text-5xl font-bold font-[var(--font-heading)] mb-12 animate-fade-in-up">
        {i18n.about.title}
      </h1>

      <!-- Mission -->
      <section class="mb-16 animate-fade-in-up animate-delay-100">
        <h2 class="text-2xl font-semibold font-[var(--font-heading)] mb-4 flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-[var(--color-gradient-start)] to-[var(--color-gradient-end)] flex items-center justify-center text-white text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </span>
          {i18n.about.mission}
        </h2>
        <p class="text-[var(--color-text-secondary)] leading-relaxed text-lg">
          {i18n.about.missionText}
        </p>
      </section>

      <!-- What we do -->
      <section class="mb-16 animate-fade-in-up animate-delay-200">
        <h2 class="text-2xl font-semibold font-[var(--font-heading)] mb-6 flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-[var(--color-gradient-start)] to-[var(--color-gradient-end)] flex items-center justify-center text-white text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
          </span>
          {i18n.about.what}
        </h2>
        <div class="space-y-4">
          {i18n.about.whatItems.map((item, idx) => (
            <div class="flex items-start gap-4 p-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]">
              <span class="w-7 h-7 rounded-lg bg-[var(--color-accent-soft)] flex items-center justify-center text-[var(--color-accent)] text-sm font-semibold shrink-0">
                {idx + 1}
              </span>
              <p class="text-[var(--color-text-secondary)] leading-relaxed">
                {item}
              </p>
            </div>
          ))}
        </div>
      </section>

      <!-- Contact -->
      <section class="animate-fade-in-up animate-delay-300">
        <h2 class="text-2xl font-semibold font-[var(--font-heading)] mb-4 flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-[var(--color-gradient-start)] to-[var(--color-gradient-end)] flex items-center justify-center text-white text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </span>
          {i18n.about.contact}
        </h2>
        <p class="text-[var(--color-text-secondary)] mb-6">{i18n.about.contactText}</p>
        <div class="flex flex-wrap gap-3">
          <a
            href="https://github.com/funAgent"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text-secondary)] font-medium text-sm transition-all hover:border-[var(--color-accent)]/30 hover:text-[var(--color-text)] hover:-translate-y-0.5"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            GitHub
          </a>
          <a
            href="https://x.com/funAgentApp"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text-secondary)] font-medium text-sm transition-all hover:border-[var(--color-accent)]/30 hover:text-[var(--color-text)] hover:-translate-y-0.5"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
            X (Twitter)
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Base>
